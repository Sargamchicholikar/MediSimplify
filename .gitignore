**/__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo

# Environment & Secrets
.env
*.env
!.env.example
*.key
google-credentials.json

# Virtual Environment
venv/
env/
ENV/

# Data & Collections
collected_data/
backend/data/
data/
backend/data/audio/
*.mp3
*.wav

# Analytics & Feedback (Private)
analytics/
backend/analytics/
user_feedback/
backend/user_feedback/
backend/exports/
exports/

# Private Python Files
backend/data_collector.py
backend/analytics_tracker.py
backend/feedback_collector.py
backend/excel_exporter.py

# Private Frontend
frontend/dashboard.html

# Cache Files
drug_cache.json
backend/data/drug_cache.json

# Test Files
test/

# IDEs
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log

# Temp
*.tmp
