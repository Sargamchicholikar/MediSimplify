{
  "version": 2,
  "builds": [
    {
      "src": "backend/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/styles.css",
      "dest": "frontend/styles.css"
    },
    {
      "src": "/script.js",
      "dest": "frontend/script.js"
    },
    {
      "src": "/about",
      "dest": "backend/index.py"
    },
    {
      "src": "/analyze-(.*)",
      "dest": "backend/index.py"
    },
    {
      "src": "/upload-(.*)",
      "dest": "backend/index.py"
    },
    {
      "src": "/generate-audio",
      "dest": "backend/index.py"
    },
    {
      "src": "/admin/(.*)",
      "dest": "backend/index.py"
    },
    {
      "src": "/analytics",
      "dest": "backend/index.py"
    },
    {
      "src": "/",
      "dest": "frontend/index.html"
    }
  ]
}
